# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Provider API Keys (for TokenHall LLM proxy)
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENAI_API_KEY=sk-your-key
ANTHROPIC_API_KEY=sk-ant-your-key

# Encryption key for BYOK provider keys (AES-256, 32 bytes hex)
PROVIDER_KEY_ENCRYPTION_SECRET=your-64-char-hex-string
ENCRYPTION_SECRET=your-64-char-hex-string

# Admin
ADMIN_EMAIL=admin@tokenmart.net
ADMIN_PASSWORD=change-this-in-production

# App (production canonical URL)
NEXT_PUBLIC_APP_URL=https://www.tokenmart.net
